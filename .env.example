# -----------------------------------------------------------------------------
# Uttera TTS vLLM — example environment
# Copy to .env and tweak for your deployment.
# -----------------------------------------------------------------------------

DEBUG=false

# Network
HOST=0.0.0.0
PORT=9004

# -----------------------------------------------------------------------------
# Model (VoxCPM2 via nano-vllm-voxcpm)
# -----------------------------------------------------------------------------

VOXCPM_MODEL=openbmb/VoxCPM2
SERVED_MODEL_NAME=tts-1

# -----------------------------------------------------------------------------
# nano-vllm-voxcpm engine tuning
# -----------------------------------------------------------------------------
# How the engine uses VRAM (from `nanovllm_voxcpm/engine/model_runner.py:230`):
#     available_budget = total_gpu_memory × VLLM_GPU_MEM_UTIL − peak
#     num_kvcache_blocks = available_budget // per_block_size
# The engine consumes the WHOLE available_budget as KV cache blocks
# regardless of whether max_num_seqs × max_model_len would need that much.
# `util` is therefore a target VRAM reservation, not a functional need.
#
# CUDA graphs (captured on startup unless enforce_eager=true — which we do
# NOT recommend; it costs 2-3× in throughput) expand into whatever free VRAM
# remains on the device. Total process VRAM is thus approximately:
#     weights (~5 GB) + KV cache (budget) + remaining free slots → CUDA graphs
#
# Empirical benchmark on RTX 5090 (32 GB) with the canonical uttera-tts-40w
# corpus, enforce_eager left at upstream default (false, CUDA graphs on):
#
#   UTIL    Actual VRAM   burst-64 wall/rps       burst-256 wall/rps      Note
#   ────    ───────────   ──────────────────      ──────────────────      ────
#   0.30    fail          `num_kvcache_blocks>0` assertion on startup
#   0.40    22.0 GB       20.1 s / 3.19 rps       60.9 s / 4.20 rps       safe
#   0.45    23.6 GB       20.6 s / 3.11 rps       59.1 s / 4.33 rps   ← default (sweet spot)
#   0.85    27.8 GB       20.8 s / 3.08 rps (baseline, pre-1.4.3)        starves co-tenants
#
# Same throughput within variance across 0.40 / 0.45 / 0.85, so choose the
# lowest that still starts cleanly. 0.45 leaves ~1 GB of headroom above the
# 0.40 startup-assertion floor (~0.35 depending on HF cache + co-resident
# load on the GPU).
#
# Per-GPU starting points (leave enforce_eager at the upstream default):
#
#   GPU (VRAM)                      UTIL          MAX_NUM_SEQS   MAX_MODEL_LEN
#   ────────────────────────────    ─────         ────────────   ─────────────
#   RTX 5070 / 5080 (16 GB)         0.75          8              4096
#   RTX 3090 / 4090 (24 GB)         0.55          16             4096
#   RTX 5090 (32 GB)                0.45 (dflt)   32             4096
#   RTX PRO 5000 Ada (48 GB)        0.35          32             4096
#   RTX PRO 6000 Ada (96 GB)        0.20          64             4096
#
# If you hit `num_kvcache_blocks > 0` assertion on startup: util is too low
# for the current model + GPU state, raise by 0.05 and retry.

VLLM_GPU_MEM_UTIL=0.45
VLLM_MAX_NUM_SEQS=32
VLLM_MAX_NUM_BATCHED_TOKENS=16384
VLLM_MAX_MODEL_LEN=4096
VOXCPM_INFERENCE_TIMESTEPS=10

# Default voice when the client does not specify one.
DEFAULT_VOICE=alloy

# Where voices and latents live.
VOICE_ASSET_DIR=assets/voices

# -----------------------------------------------------------------------------
# Audio cache (identical semantics to uttera-tts-hotcold)
# -----------------------------------------------------------------------------

# Deterministic MD5-keyed cache for /v1/audio/speech responses.
# Key = md5(model + voice + speed + format + params + text). Cache is
# bypassed when the request uploads a speaker_wav (adhoc cloning).
# Set AUDIO_CACHE_DIR to an absolute path or leave empty to use
# `assets/cache` relative to the repo root.
AUDIO_CACHE_DIR=
# Cache TTL in minutes. 10080 = 7 days. Set to 0 to disable the cache
# entirely (every request regenerates from scratch).
CACHE_TTL_MINUTES=10080

# -----------------------------------------------------------------------------
# Routing telemetry (same knob as the other Uttera repos)
# -----------------------------------------------------------------------------

ROUTING_DRAIN_CAP_SECONDS=120

# -----------------------------------------------------------------------------
# Optional: Redis self-registration for upstream router discovery
# -----------------------------------------------------------------------------

REDIS_URL=
NODE_ID=
NODE_HOST=localhost
NODE_PORT=9004
REDIS_PUBLISH_INTERVAL=0.5

# -----------------------------------------------------------------------------
# Asset cache (HF model snapshots)
# -----------------------------------------------------------------------------

# XDG_CACHE_HOME=/path/to/assets/models
