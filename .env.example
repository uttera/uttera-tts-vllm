# -----------------------------------------------------------------------------
# Uttera TTS vLLM — example environment
# Copy to .env and tweak for your deployment.
# -----------------------------------------------------------------------------

DEBUG=false

# Network
HOST=0.0.0.0
PORT=5100

# -----------------------------------------------------------------------------
# Model (VoxCPM2 via nano-vllm-voxcpm)
# -----------------------------------------------------------------------------

VOXCPM_MODEL=openbmb/VoxCPM2
SERVED_MODEL_NAME=tts-1

# -----------------------------------------------------------------------------
# nano-vllm-voxcpm engine tuning
# Defaults validated on RTX 5090 (32 GB). Reduce on smaller GPUs.
# -----------------------------------------------------------------------------

VLLM_GPU_MEM_UTIL=0.85
VLLM_MAX_NUM_SEQS=32
VLLM_MAX_NUM_BATCHED_TOKENS=16384
VLLM_MAX_MODEL_LEN=4096
VOXCPM_INFERENCE_TIMESTEPS=10

# Default voice when the client does not specify one.
DEFAULT_VOICE=alloy

# Where voices and latents live.
VOICE_ASSET_DIR=assets/voices

# -----------------------------------------------------------------------------
# Audio cache (identical semantics to uttera-tts-hotcold)
# -----------------------------------------------------------------------------

# Deterministic MD5-keyed cache for /v1/audio/speech responses.
# Key = md5(model + voice + speed + format + params + text). Cache is
# bypassed when the request uploads a speaker_wav (adhoc cloning).
# Set AUDIO_CACHE_DIR to an absolute path or leave empty to use
# `assets/cache` relative to the repo root.
AUDIO_CACHE_DIR=
# Cache TTL in minutes. 10080 = 7 days. Set to 0 to disable the cache
# entirely (every request regenerates from scratch).
CACHE_TTL_MINUTES=10080

# -----------------------------------------------------------------------------
# Routing telemetry (same knob as the other Uttera repos)
# -----------------------------------------------------------------------------

ROUTING_DRAIN_CAP_SECONDS=120

# -----------------------------------------------------------------------------
# Optional: Redis self-registration for upstream router discovery
# -----------------------------------------------------------------------------

REDIS_URL=
NODE_ID=
NODE_HOST=localhost
NODE_PORT=5100
REDIS_PUBLISH_INTERVAL=0.5

# -----------------------------------------------------------------------------
# Asset cache (HF model snapshots)
# -----------------------------------------------------------------------------

# XDG_CACHE_HOME=/path/to/assets/models
